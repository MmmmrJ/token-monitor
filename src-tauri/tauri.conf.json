{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Token Monitor",
  "version": "1.2.0",
  "identifier": "com.codexusagemonitor.desktop",
  "build": {
    "beforeDevCommand": "npm run start",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://127.0.0.1:4173",
    "frontendDist": "../dist"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "title": "Token Monitor",
        "width": 620,
        "height": 360,
        "minWidth": 480,
        "minHeight": 300,
        "decorations": false,
        "transparent": true,
        "backgroundColor": [
          0,
          0,
          0,
          0
        ],
        "shadow": false,
        "resizable": true,
        "visible": true,
        "alwaysOnTop": false
      }
    ],
    "macOSPrivateApi": true,
    "security": {
      "csp": "default-src 'self'; connect-src 'self' https://github.com https://*.github.com https://objects.githubusercontent.com; img-src 'self' data:; style-src 'self' 'unsafe-inline'; font-src 'self' data:;"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "targets": [
      "dmg",
      "app",
      "msi",
      "nsis"
    ],
    "category": "DeveloperTool",
    "shortDescription": "Monitor local Codex and Cursor usage",
    "longDescription": "A compact desktop widget that reads usage limits from the current local Codex or Cursor sign-in session."
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEE1RUMwQjVFRDU3ODJENUMKUldSY0xYalZYZ3ZzcGZoTGlQaU9VdWhRZGFhNTdJMThmSHZWQWR4WVZQbmV6WmIxcGc1L3JKRWsK",
      "endpoints": [
        "https://github.com/MmmmrJ/token-monitor/releases/latest/download/latest.json"
      ]
    }
  }
}
